        <div className="space-y-6">
            <h2 className="text-2xl font-bold mb-4">📊 Platform Overview</h2>
            <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div className="bg-gray-800/50 p-4 rounded-lg">
                    <div className="text-gray-400 text-sm">Total Deposited</div>
                    <div className="text-2xl font-bold text-green-400">
                        {stats ? Number(formatUnits(stats[1], 18)).toFixed(2) : '0'} USDT
                    </div>
                </div>
                <div className="bg-gray-800/50 p-4 rounded-lg">
                    <div className="text-gray-400 text-sm">Total Withdrawn</div>
                    <div className="text-2xl font-bold text-red-400">
                        {stats ? Number(formatUnits(stats[2], 18)).toFixed(2) : '0'} USDT
                    </div>
                </div>
                <div className="bg-gray-800/50 p-4 rounded-lg">
                    <div className="text-gray-400 text-sm">Total Payouts</div>
                    <div className="text-2xl font-bold text-blue-400">
                        {stats ? Number(formatUnits(stats[3], 18)).toFixed(2) : '0'} USDT
                    </div>
                </div>
                <div className="bg-gray-800/50 p-4 rounded-lg">
                    <div className="text-gray-400 text-sm">Total Commissions</div>
                    <div className="text-2xl font-bold text-purple-400">
                        {stats ? Number(formatUnits(stats[4], 18)).toFixed(2) : '0'} USDT
                    </div>
                </div>
                <div className="bg-gray-800/50 p-4 rounded-lg">
                    <div className="text-gray-400 text-sm">Total Turnover</div>
                    <div className="text-2xl font-bold text-yellow-400">
                        {stats ? Number(formatUnits(stats[5], 18)).toFixed(2) : '0'} USDT
                    </div>
                </div>
                <div className="bg-gray-800/50 p-4 rounded-lg">
                    <div className="text-gray-400 text-sm">Platform Health</div>
                    <div className="text-2xl font-bold text-green-400">
                        ✅ Operational
                    </div>
                </div>
            </div>

            {/* Financial Summary Chart */}
            <div className="bg-gray-800/30 p-6 rounded-lg mt-6">
                <h3 className="text-lg font-bold mb-4">📈 Financial Summary</h3>
                <div className="space-y-3">
                    <div className="flex justify-between items-center">
                        <span className="text-gray-400">Total Deposits</span>
                        <span className="text-green-400 font-bold">{stats ? Number(formatUnits(stats[1], 18)).toFixed(2) : '0'} USDT</span>
                    </div>
                    <div className="flex justify-between items-center">
                        <span className="text-gray-400">Total Withdrawals</span>
                        <span className="text-red-400 font-bold">-{stats ? Number(formatUnits(stats[2], 18)).toFixed(2) : '0'} USDT</span>
                    </div>
                    <div className="flex justify-between items-center">
                        <span className="text-gray-400">Total Payouts</span>
                        <span className="text-blue-400 font-bold">-{stats ? Number(formatUnits(stats[3], 18)).toFixed(2) : '0'} USDT</span>
                    </div>
                    <div className="flex justify-between items-center">
                        <span className="text-gray-400">Total Commissions</span>
                        <span className="text-purple-400 font-bold">-{stats ? Number(formatUnits(stats[4], 18)).toFixed(2) : '0'} USDT</span>
                    </div>
                    <div className="border-t border-gray-700 pt-3 flex justify-between items-center">
                        <span className="text-white font-bold">Net Platform Flow</span>
                        <span className="text-yellow-400 font-bold text-xl">
                            {stats ? (
                                Number(formatUnits(stats[1], 18)) - 
                                Number(formatUnits(stats[2], 18)) - 
                                Number(formatUnits(stats[3], 18)) - 
                                Number(formatUnits(stats[4], 18))
                            ).toFixed(2) : '0'} USDT
                        </span>
                    </div>
                </div>
            </div>
        </div>
    );
}

// Users Tab with full list
function UsersTab({ totalUsers, setSelectedUserId }: any) {
    const [searchId, setSearchId] = useState('');
    const [page, setPage] = useState(1);
    const perPage = 20;
    
    const filteredUsers = searchId ? [parseInt(searchId)] : Array.from({ length: totalUsers }, (_, i) => i + 1);
    const paginatedUsers = filteredUsers.slice((page - 1) * perPage, page * perPage);
    const totalPages = Math.ceil(filteredUsers.length / perPage);
    
    return (
        <div className="space-y-6">
            <div className="flex justify-between items-center">
                <h2 className="text-2xl font-bold">👥 User Management ({totalUsers} users)</h2>
                <input
                    type="number"
                    placeholder="Search User ID..."
                    value={searchId}
                    onChange={(e) => setSearchId(e.target.value)}
                    className="bg-gray-800 border border-gray-700 rounded-lg px-4 py-2 text-white"
                />
            </div>

            <div className="overflow-x-auto">
                <table className="w-full">
                    <thead>
                        <tr className="border-b border-gray-700 text-left">
                            <th className="p-3 text-gray-400 text-sm">ID</th>
                            <th className="p-3 text-gray-400 text-sm">Address</th>
                            <th className="p-3 text-gray-400 text-sm">Ref Code</th>
                            <th className="p-3 text-gray-400 text-sm">Status</th>
                            <th className="p-3 text-gray-400 text-sm">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {paginatedUsers.map(userId => (
                            <UserRowAdvanced key={userId} userId={userId} onClick={() => setSelectedUserId(userId)} />
                        ))}
                    </tbody>
                </table>
            </div>

            {/* Pagination */}
            {totalPages > 1 && (
                <div className="flex justify-center gap-2 mt-4">
                    <button
                        onClick={() => setPage(p => Math.max(1, p - 1))}
                        disabled={page === 1}
                        className="bg-gray-800 hover:bg-gray-700 disabled:bg-gray-900 text-white px-4 py-2 rounded"
                    >
                        Previous
                    </button>
                    <span className="bg-gray-800 text-white px-4 py-2 rounded">
                        Page {page} of {totalPages}
                    </span>
                    <button
                        onClick={() => setPage(p => Math.min(totalPages, p + 1))}
                        disabled={page === totalPages}
                        className="bg-gray-800 hover:bg-gray-700 disabled:bg-gray-900 text-white px-4 py-2 rounded"
                    >
                        Next
                    </button>
                </div>
            )}
        </div>
    );
}

// User Row Component
function UserRowAdvanced({ userId, onClick }: any) {
    const { data: addr } = useReadContract({
        address: TRK_GAME_ADDRESS,
        abi: TRKGameABI.abi,
        functionName: 'idToAddress',
        args: [BigInt(userId)],
    });

    const { data: refCode } = useReadContract({
        address: TRK_GAME_ADDRESS,
        abi: TRKGameABI.abi,
        functionName: 'addressToReferralCode',
        args: [addr || '0x0000000000000000000000000000000000000000'],
    });

    const { data: userData } = useReadContract({
        address: TRK_GAME_ADDRESS,
        abi: TRKGameABI.abi,
        functionName: 'users',
        args: [addr || '0x0000000000000000000000000000000000000000'],
    });

    if (!addr || addr === '0x0000000000000000000000000000000000000000') {
        return null;
    }

    const user = userData as any;
    const isActive = user ? user[10] : false;
    const isReal = user ? user[11] : false;

    return (
        <tr className="border-b border-gray-800 hover:bg-gray-800/50 transition-colors cursor-pointer" onClick={onClick}>
            <td className="p-3 font-mono">#{userId}</td>
            <td className="p-3 font-mono text-sm text-blue-400">{(addr as string).slice(0, 10)}...{(addr as string).slice(-8)}</td>
            <td className="p-3 font-mono text-green-400">{refCode ? String(refCode) : 'Loading...'}</td>
            <td className="p-3">
                {isActive ? (
                    isReal ? (
                        <span className="bg-yellow-900/50 text-yellow-400 text-xs px-2 py-1 rounded">💎 REAL CASH</span>
                    ) : (
                        <span className="bg-blue-900/50 text-blue-400 text-xs px-2 py-1 rounded">🎮 PRACTICE</span>
                    )
                ) : (
                    <span className="bg-gray-900/50 text-gray-400 text-xs px-2 py-1 rounded">❌ INACTIVE</span>
                )}
            </td>
            <td className="p-3">
                <button className="bg-blue-600 hover:bg-blue-700 text-white text-xs px-3 py-1 rounded">
                    View Details
                </button>
            </td>
        </tr>
    );
}

