            </div>

            <div className="bg-blue-900/20 border border-blue-500/30 rounded-lg p-4">
                <p className="text-blue-400 mb-2">📊 Complete Transaction History via BSCScan</p>
                <p className="text-gray-400 text-sm">For complete transaction logs with timestamps and tx hashes:</p>
                <a 
                    href={`https://bscscan.com/address/${TRK_GAME_ADDRESS}#events`}
                    target="_blank"
                    rel="noopener noreferrer"
