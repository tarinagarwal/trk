                    </div>
                    
                    <div className="bg-gray-800/50 p-4 rounded-lg flex justify-between items-center border-l-4 border-red-500">
                        <div>
                            <div className="text-red-400 font-mono text-sm font-bold">💸 WITHDRAWAL</div>
                            <div className="text-gray-400 text-xs">User withdrew to wallet</div>
                        </div>
                        <div className="text-right">
                            <div className="text-white font-bold">Min: 5 USDT</div>
                            <div className="text-gray-500 text-xs">Check BSCScan for details</div>
                        </div>
                    </div>

                    <div className="bg-gray-800/50 p-4 rounded-lg flex justify-between items-center border-l-4 border-blue-500">
                        <div>
                            <div className="text-blue-400 font-mono text-sm font-bold">🎲 BET PLACED</div>
                            <div className="text-gray-400 text-xs">User placed bet on number</div>
                        </div>
                        <div className="text-right">
                            <div className="text-white font-bold">Min: 1 USDT</div>
                            <div className="text-gray-500 text-xs">Check BSCScan for details</div>
                        </div>
                    </div>

                    <div className="bg-gray-800/50 p-4 rounded-lg flex justify-between items-center border-l-4 border-yellow-500">
                        <div>
                            <div className="text-yellow-400 font-mono text-sm font-bold">🎉 WIN PAYOUT</div>
                            <div className="text-gray-400 text-xs">Winner received payout (36x)</div>
                        </div>
                        <div className="text-right">
                            <div className="text-white font-bold">36x Multiplier</div>
                            <div className="text-gray-500 text-xs">Check BSCScan for details</div>
                        </div>
                    </div>

                    <div className="bg-gray-800/50 p-4 rounded-lg flex justify-between items-center border-l-4 border-purple-500">
                        <div>
                            <div className="text-purple-400 font-mono text-sm font-bold">💰 COMMISSION</div>
                            <div className="text-gray-400 text-xs">Referral commission distributed</div>
                        </div>
                        <div className="text-right">
                            <div className="text-white font-bold">6-Level System</div>
