                    View All Events on BSCScan →
                </a>
            </div>

            {/* Transaction Summary */}
            <div className="space-y-3">
                <h3 className="text-lg font-bold">Recent Activity (Live)</h3>
                <div className="space-y-2">
                    <div className="bg-gray-800/50 p-4 rounded-lg flex justify-between items-center border-l-4 border-green-500">
                        <div>
                            <div className="text-green-400 font-mono text-sm font-bold">💰 DEPOSIT</div>
