'use client';

import { useAccount, useReadContract, useWriteContract } from 'wagmi';
import { formatUnits } from 'viem';
import { TRK_GAME_ADDRESS } from '../../config';
import TRKGameABI from '../../abis/TRKRouter.json';
import { useState } from 'react';

export default function AdvancedAdminPanel() {
    const { address, isConnected } = useAccount();
    const [activeTab, setActiveTab] = useState('overview');
    const [selectedUserId, setSelectedUserId] = useState<number | null>(null);
    const [historyFilter, setHistoryFilter] = useState('all');

    // Check if user is owner
    const { data: ownerAddress } = useReadContract({
        address: TRK_GAME_ADDRESS,
        abi: TRKGameABI.abi,
        functionName: 'owner',
    });

    const isOwner = ownerAddress && address && 
        (ownerAddress as string).toLowerCase() === address.toLowerCase();

    // Global stats
    const { data: totalUsers } = useReadContract({
        address: TRK_GAME_ADDRESS,
        abi: TRKGameABI.abi,
        functionName: 'lastUserId',
    });

    const { data: globalStats } = useReadContract({
        address: TRK_GAME_ADDRESS,
        abi: TRKGameABI.abi,
        functionName: 'globalStats',
    });

    const { data: currentRoundId } = useReadContract({
        address: TRK_GAME_ADDRESS,
        abi: TRKGameABI.abi,
        functionName: 'currentRoundId',
    });

    const { data: adminBalance } = useReadContract({
        address: TRK_GAME_ADDRESS,
        abi: TRKGameABI.abi,
        functionName: 'companyBalance',
    });

    const { writeContract, isPending } = useWriteContract();

    if (!isConnected) {
        return (
            <div className="min-h-screen bg-gradient-to-b from-gray-900 via-black to-gray-900 flex items-center justify-center">
                <div className="text-center">
                    <h2 className="text-2xl font-bold text-white mb-4">🔐 Admin Panel Access</h2>
                    <p className="text-gray-400">Please connect your wallet to continue</p>
                </div>
            </div>
        );
    }

    if (!isOwner) {
        return (
            <div className="min-h-screen bg-gradient-to-b from-gray-900 via-black to-gray-900 flex items-center justify-center">
                <div className="text-center">
                    <h2 className="text-2xl font-bold text-red-500 mb-4">⛔ Access Denied</h2>
                    <p className="text-gray-400">You are not authorized to access this panel</p>
                    <p className="text-gray-500 text-sm mt-2 font-mono">{address}</p>
                </div>
            </div>
        );
    }

    const stats = globalStats as any;
    const totalUsersCount = totalUsers ? Number(totalUsers) - 1 : 0;

    return (
        <div className="min-h-screen bg-gradient-to-b from-gray-900 via-black to-gray-900 text-white p-8">
            <div className="max-w-7xl mx-auto">
                {/* Header */}
                <div className="mb-8">
                    <h1 className="text-4xl font-bold mb-2">🎮 Advanced Admin Panel</h1>
                    <p className="text-gray-400">Complete control and monitoring dashboard</p>
                    <p className="text-xs text-gray-600 font-mono mt-2">Contract: {TRK_GAME_ADDRESS}</p>
                </div>

                {/* Quick Stats */}
                <div className="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
                    <div className="bg-blue-900/20 border border-blue-500/30 rounded-xl p-6">
                        <div className="text-blue-400 text-sm mb-2">👥 Total Users</div>
                        <div className="text-3xl font-bold">{totalUsersCount}</div>
                    </div>
                    <div className="bg-green-900/20 border border-green-500/30 rounded-xl p-6">
                        <div className="text-green-400 text-sm mb-2">💰 Total Deposited</div>
                        <div className="text-3xl font-bold">{stats ? Number(formatUnits(stats[1], 18)).toFixed(2) : '0'} <span className="text-lg">USDT</span></div>
                    </div>
                    <div className="bg-purple-900/20 border border-purple-500/30 rounded-xl p-6">
                        <div className="text-purple-400 text-sm mb-2">🎲 Current Round</div>
                        <div className="text-3xl font-bold">#{currentRoundId ? currentRoundId.toString() : '0'}</div>
                    </div>
                    <div className="bg-yellow-900/20 border border-yellow-500/30 rounded-xl p-6">
                        <div className="text-yellow-400 text-sm mb-2">🏦 Admin Balance</div>
                        <div className="text-3xl font-bold">{adminBalance ? Number(formatUnits(adminBalance as bigint, 18)).toFixed(2) : '0'} <span className="text-lg">USDT</span></div>
                    </div>
                </div>

                {/* Tabs */}
                <div className="flex gap-2 mb-6 overflow-x-auto">
                    {['overview', 'users', 'transactions', 'rounds', 'finance', 'settings'].map(tab => (
                        <button
                            key={tab}
                            onClick={() => setActiveTab(tab)}
                            className={`px-6 py-3 rounded-lg font-medium transition-all whitespace-nowrap ${
                                activeTab === tab
                                    ? 'bg-blue-600 text-white'
                                    : 'bg-gray-800 text-gray-400 hover:bg-gray-700'
                            }`}
                        >
                            {tab.charAt(0).toUpperCase() + tab.slice(1)}
                        </button>
                    ))}
                </div>

                {/* Tab Content */}
                <div className="bg-gray-900/50 border border-gray-800 rounded-xl p-6">
                    {activeTab === 'overview' && <OverviewTab stats={stats} />}
                    {activeTab === 'users' && <UsersTab totalUsers={totalUsersCount} setSelectedUserId={setSelectedUserId} />}
                    {activeTab === 'transactions' && <TransactionsTab filter={historyFilter} setFilter={setHistoryFilter} />}
                    {activeTab === 'rounds' && <RoundsTab currentRoundId={currentRoundId} writeContract={writeContract} isPending={isPending} />}
                    {activeTab === 'finance' && <FinanceTab adminBalance={adminBalance} writeContract={writeContract} isPending={isPending} />}
                    {activeTab === 'settings' && <SettingsTab writeContract={writeContract} isPending={isPending} />}
                </div>

                {/* User Detail Modal */}
                {selectedUserId && (
                    <UserDetailModal userId={selectedUserId} onClose={() => setSelectedUserId(null)} />
                )}
            </div>
        </div>
    );
}

